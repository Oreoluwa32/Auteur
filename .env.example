# Alibaba Cloud / DashScope — Singapore region (-intl)
DASHSCOPE_API_KEY=sk-...
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Models (override defaults here)
MODEL_DIRECTOR=qwen-max
MODEL_WRITER=qwen-plus
MODEL_CRITIC=qwen-vl-max
MODEL_IMAGE=wanx2.1-t2i-turbo
MODEL_I2V=wan2.1-i2v-turbo
MODEL_T2V=wan2.1-t2v-turbo

# Pipeline config
CRITIC_THRESHOLD=0.7
MAX_SHOT_ATTEMPTS=3
PARALLEL_SHOT_LIMIT=3
JOB_POLL_INTERVAL=10
JOB_TIMEOUT=600

# Storage
PROJECT_DIR=./projects
OUTPUT_DIR=./output
